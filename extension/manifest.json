{
  "manifest_version": 3,
  "name": "Surge",
  "version": "1.0.0",
  "description": "A 5x6 board strategy game with a self-improving local MCTS opponent. No network calls, no servers -- the agent learns entirely in your browser.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Surge"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": ["storage"]
}
